# Copy to .env.local and fill in to enable cloud sync + multi-user.
# Leave unset to run GymLog in single-user, local-only mode (no backend).
#
# These come from your Supabase project: Settings → API.
# The anon key is PUBLIC by design — security is enforced by RLS + the
# PIN-checked RPC functions in supabase/schema.sql, not by hiding this key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
